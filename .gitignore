# Zig build outputs
.zig-cache/
zig-cache/
zig-out/

# Compiled / linker artifacts
*.exe
*.obj
*.pdb
*.o
*.a
*.lib
*.s

# Toolchains / large external trees (kept out of source control)
.tools/

# PGO raw profiles (regenerate locally). The merged profile is re-included further down
# so CI/release builds are PGO-optimized + reproducible.
*.profraw

# Local logs, run output, and scratch/experiment dirs
*.log
*.out
_*/
oracle/build/

# ...but re-include just the merged PGO profile (the _*/ rule above excludes _pgo/).
!_pgo/
_pgo/*
!_pgo/merged.profdata

# release.sh build staging (the published copies live in releases/<version>/ + on the
# GitHub Release page; releases/ itself stays tracked). _build/ is covered by _*/ above.
dist/
